{
    "compilerOptions": {
        "target": "ES2022",
        "module": "commonjs",
        "moduleResolution": "node",
        "strict": true,
        "noImplicitAny": true,
        "ignoreDeprecations": "6.0",
        "esModuleInterop": true,
        "types": [
            "node"
        ],
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "rootDir": ".",
        "outDir": "dist"
    },
    "include": [
        "shared/**/*.ts",
        "build/**/*.ts"
    ]
}
